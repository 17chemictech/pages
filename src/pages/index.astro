---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Newsletter from "../components/Newsletter.astro";
import Icon from "../components/Icon.astro";
import autumnScene from "../assets/autumn-scene.webp";
import {
  SITE,
  categories,
  featuredPost,
  sortedPosts,
  getAuthor,
  getCategory,
  formatDate,
} from "../lib/blog-data.js";

const featured = await featuredPost();
const featuredAuthor = getAuthor(featured.author);
const featuredCategory = getCategory(featured.category);
const latest = (await sortedPosts()).filter((post) => post.slug !== featured.slug);
---

<BaseLayout
  title={`${SITE.name} - Discover essays, notes & curated internet taste`}
  description={SITE.description}
  canonical="/"
  flushFooter
>
  <section class="border-b border-border/60 bg-[radial-gradient(circle_at_top_left,_rgba(214,224,200,0.45),_transparent_36%),linear-gradient(180deg,#fffef8_0%,#fbfaf5_48%,#f7f5ef_100%)]">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:py-18">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-white/80 px-3 py-1 text-[0.7rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">
          <span class="h-2 w-2 rounded-full bg-primary"></span>
          Pages by Olivie
        </div>
        <h1 class="mt-5 max-w-3xl font-serif text-[3rem] font-semibold leading-[0.94] tracking-[-0.04em] text-foreground sm:text-[4.35rem]">
          A brighter front page for essays, bookmarks, and the things worth keeping.
        </h1>
        <p class="mt-6 max-w-xl text-base leading-7 text-muted-foreground sm:text-lg">
          Part editorial desk, part taste index. Discover long reads, small field notes, and the internet objects that deserve more than a passing scroll.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={`/blog/${featured.slug}`}
            class="inline-flex items-center gap-2 rounded-full bg-foreground px-5 py-3 text-sm font-medium text-background transition-transform hover:-translate-y-0.5"
          >
            Start with the lead story
            <Icon name="arrow-right" class="h-3.5 w-3.5" />
          </a>
          <a
            href="https://quaily.com/csworld"
            class="inline-flex items-center gap-2 rounded-full border border-border bg-white px-5 py-3 text-sm font-medium text-foreground hover:bg-muted"
          >
            Join the newsletter
          </a>
        </div>
        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-border/70 bg-white/80 p-4 shadow-[0_16px_40px_rgba(30,36,20,0.05)]">
            <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Weekly rhythm</div>
            <div class="mt-2 font-serif text-2xl text-foreground">1 note</div>
            <p class="mt-2 text-sm text-muted-foreground">A small, high-signal cadence rather than a noisy publishing treadmill.</p>
          </div>
          <div class="rounded-2xl border border-border/70 bg-white/80 p-4 shadow-[0_16px_40px_rgba(30,36,20,0.05)]">
            <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Content mix</div>
            <div class="mt-2 font-serif text-2xl text-foreground">Essays + picks</div>
            <p class="mt-2 text-sm text-muted-foreground">Longer reading paired with the lighter things people actually save and share.</p>
          </div>
          <div class="rounded-2xl border border-border/70 bg-white/80 p-4 shadow-[0_16px_40px_rgba(30,36,20,0.05)]">
            <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Destination</div>
            <div class="mt-2 font-serif text-2xl text-foreground">Quaily inbox</div>
            <p class="mt-2 text-sm text-muted-foreground">Use this page to attract attention, then turn that attention into a subscribing relationship.</p>
          </div>
        </div>
      </div>
      <div class="grid gap-4 lg:pl-4">
        <article class="overflow-hidden rounded-[2rem] border border-border/70 bg-white shadow-[0_18px_60px_rgba(31,35,25,0.09)]">
          <div class="aspect-[5/4] overflow-hidden bg-muted">
            <Image
              src={autumnScene}
              alt=""
              class="h-full w-full object-cover object-center"
              loading="eager"
              decoding="async"
              widths={[640, 960, 1280]}
              sizes="(max-width: 1024px) 100vw, 42vw"
            />
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">
              <span>Editor's spotlight</span>
              <span>{formatDate(featured.date)}</span>
            </div>
            <h2 class="mt-3 font-serif text-2xl font-semibold leading-tight text-foreground">{featured.title}</h2>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">{featured.excerpt}</p>
            <a href={`/blog/${featured.slug}`} class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-primary">
              Read feature <Icon name="arrow-right" class="h-3.5 w-3.5" />
            </a>
          </div>
        </article>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-[1.5rem] border border-border/70 bg-[#dce8cf] p-5">
            <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-foreground/68">Channel</div>
            <h3 class="mt-2 font-serif text-2xl font-semibold text-foreground">Inbox first</h3>
            <p class="mt-2 text-sm leading-6 text-foreground/72">Subscriber-only curation, launch notes, and the sharper angle behind each post.</p>
          </div>
          <div class="rounded-[1.5rem] border border-border/70 bg-[#f6ddd7] p-5">
            <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-foreground/68">Browse</div>
            <h3 class="mt-2 font-serif text-2xl font-semibold text-foreground">By mood</h3>
            <p class="mt-2 text-sm leading-6 text-foreground/72">Design, essays, interviews, field notes, and whatever feels bookmarkable this week.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border/60 bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="mb-6 flex items-center justify-between">
        <div class="text-xs font-medium uppercase tracking-[0.24em] text-muted-foreground">Curated lanes</div>
        <a href="/blog" class="text-xs text-muted-foreground hover:text-foreground">Full archive &rarr;</a>
      </div>
      <div class="grid gap-5 lg:grid-cols-4">
        <div class="rounded-[1.75rem] border border-border bg-[#f4efe7] p-6">
          <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Lane 01</div>
          <h2 class="mt-3 font-serif text-2xl font-semibold text-foreground">Read like a buyer.</h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">Think of each post as a pick: selected for utility, tone, and the chance you'll want to return to it.</p>
        </div>
        <div class="rounded-[1.75rem] border border-border bg-[#fffdf8] p-6">
          <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Lane 02</div>
          <h2 class="mt-3 font-serif text-2xl font-semibold text-foreground">Save what lingers.</h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">Shortlist the pieces with staying power, then move readers into a recurring relationship through email.</p>
        </div>
        <div class="rounded-[1.75rem] border border-border bg-[#eef2e8] p-6">
          <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Lane 03</div>
          <h2 class="mt-3 font-serif text-2xl font-semibold text-foreground">Style the archive.</h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">Categories, tags, and feature shelves make the site feel browsable rather than purely chronological.</p>
        </div>
        <div class="rounded-[1.75rem] border border-border bg-[#f9e9e2] p-6">
          <div class="text-[0.68rem] font-medium uppercase tracking-[0.24em] text-muted-foreground">Lane 04</div>
          <h2 class="mt-3 font-serif text-2xl font-semibold text-foreground">Turn discovery into return visits.</h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">The page attracts the click; the newsletter earns the second and third visit.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16" data-home-latest>
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <div class="text-xs font-medium uppercase tracking-[0.24em] text-muted-foreground">Fresh picks</div>
        <h2 class="mt-2 font-serif text-3xl font-semibold tracking-tight">Browse by category, then fall into the archive.</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          data-home-filter=""
          class="rounded-full border px-3 py-1 text-xs transition-colors border-foreground bg-foreground text-background"
        >
          All
        </button>
        {
          categories.map((category) => (
            <button
              type="button"
              data-home-filter={category.slug}
              class="rounded-full border px-3 py-1 text-xs transition-colors border-border text-muted-foreground hover:text-foreground"
            >
              {category.name}
            </button>
          ))
        }
      </div>
    </div>

    <div data-home-empty class="mt-12 rounded-md border border-dashed border-border py-16 text-center text-muted-foreground" hidden>
      Nothing here yet in this section.
    </div>

    <div class="mt-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((post, index) => <PostCard post={post} hidden={index >= 6} />)}
    </div>

    <div class="mt-12 text-center">
      <a href="/blog" class="inline-flex items-center gap-2 rounded-full border border-border bg-white px-5 py-2.5 text-sm font-medium hover:bg-muted">
        Browse the archive <Icon name="arrow-right" class="h-3.5 w-3.5" />
      </a>
    </div>
  </section>

  <Newsletter />
</BaseLayout>

<script>
  const latest = document.querySelector("[data-home-latest]");
  if (latest) {
    const buttons = [...latest.querySelectorAll("[data-home-filter]")];
    const cards = [...latest.querySelectorAll("[data-post-card]")];
    const empty = latest.querySelector("[data-home-empty]");
    const activeClasses = ["border-foreground", "bg-foreground", "text-background"];
    const inactiveClasses = ["border-border", "text-muted-foreground", "hover:text-foreground"];

    const setActive = (button, active) => {
      button.classList.toggle(activeClasses[0], active);
      button.classList.toggle(activeClasses[1], active);
      button.classList.toggle(activeClasses[2], active);
      inactiveClasses.forEach((className) => button.classList.toggle(className, !active));
    };

    const filterCards = (category) => {
      let visible = 0;
      cards.forEach((card) => {
        const match = !category || card.dataset.category === category;
        const show = match && visible < 6;
        card.hidden = !show;
        if (match) visible += 1;
      });
      if (empty) empty.hidden = visible > 0;
      buttons.forEach((button) => setActive(button, button.dataset.homeFilter === category));
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => filterCards(button.dataset.homeFilter || ""));
    });
  }
</script>
